# Copie este arquivo para .env e preencha os valores

# Conexão com o PostgreSQL no Neon (https://neon.tech)
# DATABASE_URL: string COM pooling (host contém "-pooler") — usada pelo app
DATABASE_URL="postgresql://USUARIO:SENHA@HOST-pooler/pratoscan?sslmode=require"
# DIRECT_URL: string SEM pooling (mesmo host, sem "-pooler") — usada nas migrations
DIRECT_URL="postgresql://USUARIO:SENHA@HOST/pratoscan?sslmode=require"

# Gere com: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET=""

# Chave da API da Anthropic (https://platform.claude.com) — usada só no servidor
ANTHROPIC_API_KEY=""
